  </div></div><script>
  const ids = ['itemName', 'rate', 'feePercent', 'saleUsd', 'cost', 'shipping', 'other'];
  const inputs = {};
  ids.forEach(id => inputs[id] = document.getElementById(id));

  window.onload = () => {
    inputs.rate.value = localStorage.getItem('cfg_rate') || 150;
    inputs.feePercent.value = localStorage.getItem('cfg_fee') || 15;
    updateReport();
  };

  function switchTab(pId) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById(pId).classList.add('active');
    document.getElementById(pId === 'calcPage' ? 'tab-calc' : 'tab-report').classList.add('active');
    if(pId === 'reportPage') updateReport('all');
  }

  function setShipping(v) { inputs.shipping.value = v; calc(); }
  function toggleBackCalc() { 
    const p = document.getElementById('backCalcPanel');
    p.style.display = p.style.display === 'block' ? 'none' : 'block';
  }

  function calc() {
    const val = (id) => parseFloat(inputs[id].value) || 0;
    localStorage.setItem('cfg_rate', inputs.rate.value);
    localStorage.setItem('cfg_fee', inputs.feePercent.value);

    const sJpy = Math.round(val('saleUsd') * val('rate'));
    const fJpy = Math.round(sJpy * (val('feePercent') / 100));
    const profit = sJpy - (val('cost') + val('shipping') + val('other') + fJpy);
    const pRate = sJpy > 0 ? (profit / sJpy) * 100 : 0;

    document.getElementById('salesJpy').textContent = 'LC ' + sJpy.toLocaleString();
    document.getElementById('feeJpy').textContent = 'LC ' + fJpy.toLocaleString();
    const pEl = document.getElementById('profit');
    pEl.textContent = (profit >= 0 ? 'LC ' : '-LC ') + Math.abs(profit).toLocaleString();
    pEl.style.color = profit >= 0 ? 'var(--green)' : 'var(--red)';
    document.getElementById('profitRate').textContent = pRate.toFixed(1) + '%';

    // Header rate update
    const rd = document.getElementById('rateDisplay');
    if (rd) rd.textContent = 'LC ' + (val('rate') || 150) + ' / $1';
  }
  ids.forEach(id => inputs[id].addEventListener('input', calc));

  function calcBack() {
    const target = parseFloat(document.getElementById('targetProfit').value) || 0;
    const val = (id) => parseFloat(inputs[id].value) || 0;
    const rate = val('rate');
    const fP = val('feePercent') / 100;
    if(rate <= 0) return;
    const res = (target + val('cost') + val('shipping') + val('other')) / (rate * (1 - fP));
    inputs.saleUsd.value = Math.ceil(res);
    calc();
    showToast('Sale price auto-calculated!');
  }

  function saveRecord() {
    if(!inputs.saleUsd.value) return showToast('Please enter sale price');
    const profit = parseInt(document.getElementById('profit').textContent.replace(/[A-Za-z\s,]/g, '').replace('-', '')) * (document.getElementById('profit').textContent.includes('-') ? -1 : 1);
    const record = { id: Date.now(), name: inputs.itemName.value || 'Untitled', sale: inputs.saleUsd.value, profit: profit, date: new Date().toISOString() };
    let data = JSON.parse(localStorage.getItem('ebay_global_data') || '[]');
    data.unshift(record);
    localStorage.setItem('ebay_global_data', JSON.stringify(data));
    showToast('Saved successfully! Delvey!');
  }

  function updateReport(filter = 'all') {
    const data = JSON.parse(localStorage.getItem('ebay_global_data') || '[]');
    const goal = parseInt(localStorage.getItem('cfg_goal_global') || 100000);
    let mSum = 0, pCount = 0, mCount = 0;
    const listEl = document.getElementById('historyList');
    listEl.innerHTML = '';

    document.getElementById('filter-plus').classList.remove('active-filter');
    document.getElementById('filter-minus').classList.remove('active-filter');
    if(filter === 'plus') document.getElementById('filter-plus').classList.add('active-filter');
    if(filter === 'minus') document.getElementById('filter-minus').classList.add('active-filter');

    data.forEach(item => {
      mSum += item.profit;
      if(item.profit >= 0) pCount++; else mCount++;
      let show = (filter === 'all') || (filter === 'plus' && item.profit >= 0) || (filter === 'minus' && item.profit < 0);
      if(show) {
        const div = document.createElement('div');
        div.className = 'hist-card';
        div.innerHTML = `<div><b>${item.name}</b><br><small>Sold: $${item.sale}</small></div>
                         <div style="display:flex;align-items:center;"><b style="color:${item.profit>=0?'var(--green)':'var(--red)'}">LC ${item.profit.toLocaleString()}</b>
                         <button class="hist-del" onclick="deleteItem(${item.id})">×</button></div>`;
        listEl.appendChild(div);
      }
    });
    document.getElementById('monthTotal').textContent = 'LC ' + mSum.toLocaleString();
    document.getElementById('plusCount').textContent = pCount;
    document.getElementById('minusCount').textContent = mCount;
    document.getElementById('goalText').textContent = 'Target: LC ' + goal.toLocaleString();
    const per = Math.min(100, Math.max(0, Math.round((mSum / goal) * 100)));
    document.getElementById('goalBar').style.width = per + '%';
    document.getElementById('goalBar').style.backgroundPosition = (100 - per) + '% center';
    document.getElementById('percentText').textContent = per + '%';
  }

  function deleteItem(id) {
    if(!confirm('Delete this record?')) return;
    let data = JSON.parse(localStorage.getItem('ebay_global_data') || '[]');
    data = data.filter(i => i.id !== id);
    localStorage.setItem('ebay_global_data', JSON.stringify(data));
    updateReport();
  }

  function setGoal() {
    const g = prompt('Enter your target profit (LC)', '100000');
    if(g) { localStorage.setItem('cfg_goal_global', g); updateReport(); }
  }

  function resetInputs() {
    ['itemName', 'saleUsd', 'cost', 'shipping', 'other'].forEach(id => inputs[id].value = (id==='other' ? 0 : ''));
    calc();
  }

  function clearAllData() { if(confirm('Clear all data? This cannot be undone.')) { localStorage.removeItem('ebay_global_data'); updateReport(); } }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.style.display = 'block';
    setTimeout(() => t.style.display = 'none', 2000);
  }
</script>
</body>
</html>
